<%= form_with model: product, class: "max-w-md mx-auto bg-white p-6 rounded-2xl shadow-md space-y-6" do |form| %>
  <div>
    <%= form.label :name, class: "block text-sm font-medium text-gray-700 mb-2" %>
    <%= form.text_field :name, class: "w-full rounded-lg border-gray-300 focus:border-indigo-500 focus:ring-indigo-500 shadow-sm px-4 py-2" %>
  </div>

  <div>
    <%= form.submit "Save Product", class: "w-full bg-indigo-600 text-white font-semibold py-2 px-4 rounded-lg shadow hover:bg-indigo-700 transition duration-200" %>
  </div>
<% end %>
