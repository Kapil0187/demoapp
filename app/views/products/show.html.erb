<h1 class="text-3xl font-bold text-gray-800 mb-6"><%= @product.name %></h1>

<div class="bg-white rounded-xl shadow-md p-6 max-w-lg">
  <p class="text-lg text-gray-700 mb-6">
    <span class="font-semibold">Name:</span> <%= @product.name %>
  </p>

  <div class="flex space-x-4">
    <%= link_to "Back", products_path, 
          class: "px-4 py-2 bg-gray-200 text-gray-700 rounded-lg shadow hover:bg-gray-300 transition" %>

    <%= link_to "Edit", edit_product_path(@product), 
          class: "px-4 py-2 bg-indigo-600 text-white rounded-lg shadow hover:bg-indigo-700 transition" %>

    <%= button_to "Delete", @product, method: :delete, 
          data: { turbo_confirm: "Are you sure?" }, 
          class: "px-4 py-2 bg-red-600 text-white rounded-lg shadow hover:bg-red-700 transition" %>
  </div>
</div>
